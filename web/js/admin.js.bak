// =========================
// ADMIN DASHBOARD SCRIPT
// =========================

document.addEventListener("DOMContentLoaded", () => {
  // Add search feedback styles
  const style = document.createElement('style');
  style.textContent = `
    .searching { background-color: #fff3cd !important; }
    .is-invalid { background-color: #f8d7da !important; }
    .search-input { 
      transition: all 0.3s ease;
      padding: 0.375rem 0.75rem;
      border: 1px solid #ced4da;
      border-radius: 0.25rem;
    }
    .search-input:focus { 
      border-color: #80bdff;
      box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
    }
    .search-input.searching {
      background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/></svg>');
      background-repeat: no-repeat;
      background-position: right 10px center;
      padding-right: 35px;
    }
  `;
  document.head.appendChild(style);

  // Initialize the dashboard
  loadAll();
  setupSearchListeners();
});

// =========================
// SEARCH SETUP
// =========================
function setupSearchListeners() {
  const searchConfigs = [
    { input: 'courtSearch', endpoint: 'courts' },
    { input: 'judgeSearch', endpoint: 'judges' },
    { input: 'lawyerSearch', endpoint: 'lawyers' },
    { input: 'clientSearch', endpoint: 'clients' },
    { input: 'caseSearch', endpoint: 'cases' },
    { input: 'hearingSearch', endpoint: 'hearings' },
    { input: 'judgementSearch', endpoint: 'judgements' }
  ];

  searchConfigs.forEach(config => {
    const searchInput = document.getElementById(config.input);
    if (!searchInput) {
      console.error(`Search input not found: ${config.input}`);
      return;
    }

    // Add search styling class
    searchInput.classList.add('search-input');

    // Create a debounced search function
    let searchTimeout;
    const debouncedSearch = (query) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        loadTable(config.endpoint, `${config.endpoint}TableBody`, query)
          .then(() => searchInput.classList.remove('searching'))
          .catch(error => {
            console.error(`Search failed:`, error);
            searchInput.classList.add('is-invalid');
            setTimeout(() => searchInput.classList.remove('is-invalid'), 2000);
          });
      }, 300);
    };

    // Handle input changes
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.trim();
      searchInput.classList.remove('is-invalid');
      
      if (query) {
        searchInput.classList.add('searching');
      } else {
        searchInput.classList.remove('searching');
      }

      debouncedSearch(query);
    });

    // Handle clear search (Escape key)
    searchInput.addEventListener('keyup', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        searchInput.classList.remove('searching', 'is-invalid');
        debouncedSearch('');
      }
    });

    // Add clear button
    const clearButton = document.createElement('button');
    clearButton.innerHTML = '×';
    clearButton.className = 'search-clear-btn';
    clearButton.style.cssText = `
      position: absolute;
      right: 25px;
      top: 50%;
      transform: translateY(-50%);
      border: none;
      background: none;
      font-size: 18px;
      cursor: pointer;
      padding: 0 5px;
      display: none;
    `;
    
    // Wrap input in relative container if not already
    const wrapper = searchInput.parentElement;
    if (wrapper.style.position !== 'relative') {
      wrapper.style.position = 'relative';
    }
    wrapper.appendChild(clearButton);

    // Show/hide clear button
    searchInput.addEventListener('input', () => {
      clearButton.style.display = searchInput.value ? 'block' : 'none';
    });

    // Handle clear button click
    clearButton.addEventListener('click', () => {
      searchInput.value = '';
      searchInput.classList.remove('searching', 'is-invalid');
      clearButton.style.display = 'none';
      debouncedSearch('');
      searchInput.focus();
    });
  });
}

// =========================
// LOAD ALL TABLES
// =========================
function loadAll() {
  const tables = [
    "courts", "judges", "lawyers", "clients",
    "cases", "hearings", "judgements"
  ];
  tables.forEach(endpoint => loadTable(endpoint, `${endpoint}TableBody`));
}

// =========================
// LOAD TABLE
// =========================
async function loadTable(endpoint, tbodyId, query = "") {
  try {
    const tbody = document.getElementById(tbodyId);
    if (!tbody) {
      console.error(`Table body not found: ${tbodyId}`);
      return;
    }

    // Show loading state
    tbody.innerHTML = `
      <tr>
        <td colspan="100%" class="text-center">
          <div class="spinner-border spinner-border-sm text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
          <span class="ms-2">Loading data...</span>
        </td>
      </tr>
    `;

    // Fetch data
    const response = await fetch(endpoint);
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    const data = await response.json();

    // Filter data if search query exists
    const normalizedQuery = query.toLowerCase().trim();
    const filteredData = normalizedQuery ? data.filter(record => {
      return Object.entries(record)
        .filter(([key]) => !key.toLowerCase().includes('password'))
        .some(([_, value]) => {
          if (value === null || value === undefined) return false;
          return String(value).toLowerCase().includes(normalizedQuery);
        });
    }) : data;

    // Clear table
    tbody.innerHTML = '';

    // Show no results message if needed
    if (filteredData.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="100%" class="text-center text-muted">
            ${normalizedQuery ? 'No matching records found' : 'No records available'}
          </td>
        </tr>
      `;
      return;
    }

    // Render filtered data
    filteredData.forEach(record => {
      const row = document.createElement('tr');
      
      // Get fields based on table type
      let fields = [];
      switch(tbodyId) {
        case 'judgesTableBody':
          fields = ['judgeId', 'courtId', 'firstName', 'lastName', 'designation', 'email'];
          break;
        case 'hearingsTableBody':
          fields = ['caseId', 'hearingId', 'date', 'nextDate', 'report'];
          break;
        default:
          fields = Object.keys(record);
      }

      // Create cells for each field
      fields.forEach(field => {
        const cell = document.createElement('td');
        let value = record[field];

        // Format dates
        if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}/.test(value)) {
          try {
            value = new Date(value).toLocaleDateString();
          } catch (e) {
            console.warn(`Failed to format date: ${value}`);
          }
        }

        cell.textContent = value ?? '—';
        row.appendChild(cell);
      });

      // Add action buttons
      const actionsCell = document.createElement('td');
      actionsCell.innerHTML = `
        <button class="btn btn-warning btn-sm me-1" onclick="editRecord('${endpoint}', ${record[fields[0]]})" title="Edit">
          <i class="bi bi-pencil-square"></i>
        </button>
        <button class="btn btn-danger btn-sm" onclick="deleteRecord('${endpoint}', ${record[fields[0]]})" title="Delete">
          <i class="bi bi-trash"></i>
        </button>
      `;
      row.appendChild(actionsCell);

      tbody.appendChild(row);
    });
  } catch (error) {
    console.error(`Error loading ${endpoint}:`, error);
    tbody.innerHTML = `
      <tr>
        <td colspan="100%" class="text-center text-danger">
          <i class="bi bi-exclamation-triangle me-2"></i>
          Error loading data: ${error.message}
        </td>
      </tr>
    `;
  }
}

// =========================
// DELETE RECORD
// =========================
async function deleteRecord(endpoint, id) {
  if (!confirm("Are you sure you want to delete this record?")) return;

  try {
    const response = await fetch(`${endpoint}?id=${id}`, { method: "DELETE" });
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    
    await loadTable(endpoint, `${endpoint.slice(0, -1)}TableBody`);
    
    // Show success message
    const alert = document.createElement('div');
    alert.className = 'alert alert-success position-fixed top-0 end-0 m-3';
    alert.innerHTML = 'Record deleted successfully';
    document.body.appendChild(alert);
    setTimeout(() => alert.remove(), 3000);
  } catch (error) {
    console.error('Delete error:', error);
    alert(`Error deleting record: ${error.message}`);
  }
}

// =========================
// EDIT RECORD
// =========================
async function editRecord(endpoint, id) {
  try {
    if (!endpoint || !id) {
      throw new Error('Missing endpoint or ID');
    }

    const response = await fetch(endpoint);
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }

    const data = await response.json();
    const record = data.find(r => {
      const recordId = Object.values(r)[0];
      return recordId === id || recordId === Number(id);
    });

    if (!record) {
      throw new Error(`Record with ID ${id} not found`);
    }

    // Clean up record for editing
    const type = endpoint.slice(0, -1);
    const cleanRecord = { ...record };
    
    // Format dates
    ['doj', 'registrationYear', 'filingDate', 'date', 'nextDate', 'judgementDate']
      .forEach(field => {
        if (cleanRecord[field]) {
          try {
            cleanRecord[field] = cleanRecord[field].split('T')[0];
          } catch (e) {
            console.warn(`Failed to format date for ${field}:`, e);
          }
        }
      });

    showAddModal(type, cleanRecord);
  } catch (error) {
    console.error('Edit error:', error);
    alert(`Error loading record: ${error.message}`);
  }
}

// =========================
// SHOW ADD/EDIT MODAL
// =========================
function showAddModal(type, existingData = null) {
  try {
    const modal = new bootstrap.Modal(document.getElementById('addModal'));
    const title = document.getElementById('modalTitle');
    const body = document.getElementById('modalBody');
    const saveBtn = document.getElementById('saveBtn');

    if (!modal || !title || !body || !saveBtn) {
      throw new Error('Required modal elements not found');
    }

    const isEdit = existingData !== null;
    title.textContent = `${isEdit ? 'Edit' : 'Add'} ${type.charAt(0).toUpperCase()}${type.slice(1)}`;
    body.innerHTML = generateForm(type, existingData);

    if (isEdit && existingData) {
      const idField = type + 'Id';
      saveBtn.dataset.recordId = existingData[idField] || '';
    } else {
      delete saveBtn.dataset.recordId;
    }

    saveBtn.onclick = () => saveRecord(type, modal, isEdit);
    modal.show();
  } catch (error) {
    console.error('Error showing modal:', error);
    alert(`Error showing form: ${error.message}`);
  }
}

// =========================
// SAVE RECORD
// =========================
async function saveRecord(type, modal, isEdit = false) {
  try {
    const endpoint = type + 's';
    const body = buildBody(type);

    // Validate required fields
    const missingFields = validateRequiredFields(type, body);
    if (missingFields.length > 0) {
      alert(`Please fill in required fields: ${missingFields.join(', ')}`);
      return;
    }

    // Add ID for edit operations
    if (isEdit) {
      const recordId = document.getElementById('saveBtn').dataset.recordId;
      if (recordId) {
        body[type + 'Id'] = Number(recordId);
      }
    }

    const response = await fetch(endpoint, {
      method: isEdit ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });

    if (!response.ok) {
      const errorText = await response.text();
      throw new Error(errorText || `HTTP error! status: ${response.status}`);
    }

    modal.hide();
    await loadTable(endpoint, `${type}TableBody`);

    // Show success message
    const alert = document.createElement('div');
    alert.className = 'alert alert-success position-fixed top-0 end-0 m-3';
    alert.innerHTML = `Record ${isEdit ? 'updated' : 'added'} successfully`;
    document.body.appendChild(alert);
    setTimeout(() => alert.remove(), 3000);
  } catch (error) {
    console.error('Save error:', error);
    alert(`Error saving record: ${error.message}`);
  }
}

// =========================
// FORM VALIDATION
// =========================
function validateRequiredFields(type, body) {
  const required = {
    court: ['courtName', 'city', 'state', 'type'],
    judge: ['courtId', 'firstName', 'lastName', 'designation', 'email'],
    lawyer: ['firstName', 'lastName', 'email', 'specialization', 'licenceNo'],
    client: ['clientName', 'clientEmail', 'clientAddress'],
    case: ['caseTitle', 'filingDate', 'courtId', 'judgeId'],
    hearing: ['caseId', 'hearingId', 'date', 'report'],
    judgement: ['caseId', 'judgementId', 'judgementDate', 'verdict']
  };

  return (required[type] || []).filter(field => !body[field]);
}

// =========================
// BUILD REQUEST BODY
// =========================
function buildBody(type) {
  const body = {};
  const form = document.getElementById('modalBody');
  const inputs = form.querySelectorAll('input, select, textarea');
  
  inputs.forEach(input => {
    if (input.id) {
      let value = input.value.trim();
      if (input.type === 'number') {
        value = value ? Number(value) : null;
      }
      body[input.id] = value || null;
    }
  });
  
  return body;
}

// =========================
// GENERATE FORM
// =========================
function generateForm(type, data = null) {
  const val = (k) => {
    if (!data) return '';
    const value = data[k];
    if (value && ['doj', 'registrationYear', 'filingDate', 'date', 'nextDate', 'judgementDate'].includes(k)) {
      return value.split('T')[0];
    }
    return value ?? '';
  };

  const forms = {
    court: `
      <div class="mb-3">
        <input class="form-control" id="courtName" value="${val('courtName')}" placeholder="Court Name" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="city" value="${val('city')}" placeholder="City" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="state" value="${val('state')}" placeholder="State" required>
      </div>
      <div class="mb-3">
        <select class="form-control" id="type" required>
          <option value="">Select Court Type</option>
          <option value="Civil" ${val('type') === 'Civil' ? 'selected' : ''}>Civil Court</option>
          <option value="Family" ${val('type') === 'Family' ? 'selected' : ''}>Family Court</option>
          <option value="Criminal" ${val('type') === 'Criminal' ? 'selected' : ''}>Criminal Court</option>
          <option value="Commercial" ${val('type') === 'Commercial' ? 'selected' : ''}>Commercial Court</option>
          <option value="Corporate" ${val('type') === 'Corporate' ? 'selected' : ''}>Corporate Court</option>
          <option value="Juvenile" ${val('type') === 'Juvenile' ? 'selected' : ''}>Juvenile Court</option>
        </select>
      </div>`,
    judge: `
      <div class="mb-3">
        <input class="form-control" id="courtId" value="${val('courtId')}" placeholder="Court ID" required type="number">
      </div>
      <div class="mb-3">
        <input class="form-control" id="firstName" value="${val('firstName')}" placeholder="First Name" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="lastName" value="${val('lastName')}" placeholder="Last Name" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="designation" value="${val('designation')}" placeholder="Designation" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="email" value="${val('email')}" placeholder="Email" required type="email">
      </div>
      <div class="mb-3">
        <input class="form-control" id="doj" type="date" value="${val('doj')}" required>
      </div>`,
    lawyer: `
      <div class="mb-3">
        <input class="form-control" id="firstName" value="${val('firstName')}" placeholder="First Name" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="lastName" value="${val('lastName')}" placeholder="Last Name" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="email" value="${val('email')}" placeholder="Email" required type="email">
      </div>
      <div class="mb-3">
        <input class="form-control" id="address" value="${val('address')}" placeholder="Address" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="specialization" value="${val('specialization')}" placeholder="Specialization" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="licenceNo" value="${val('licenceNo')}" placeholder="Licence No" required type="number">
      </div>
      <div class="mb-3">
        <input class="form-control" id="registrationYear" type="date" value="${val('registrationYear')}" required>
      </div>`,
    client: `
      <div class="mb-3">
        <input class="form-control" id="clientName" value="${val('clientName')}" placeholder="Client Name" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="clientEmail" value="${val('clientEmail')}" placeholder="Email" required type="email">
      </div>
      <div class="mb-3">
        <textarea class="form-control" id="clientAddress" placeholder="Address" required>${val('clientAddress')}</textarea>
      </div>`,
    case: `
      <div class="mb-3">
        <input class="form-control" id="caseTitle" value="${val('caseTitle')}" placeholder="Case Title" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="filingDate" type="date" value="${val('filingDate')}" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="courtId" value="${val('courtId')}" placeholder="Court ID" required type="number">
      </div>
      <div class="mb-3">
        <input class="form-control" id="judgeId" value="${val('judgeId')}" placeholder="Judge ID" required type="number">
      </div>`,
    hearing: `
      <div class="mb-3">
        <input class="form-control" id="caseId" value="${val('caseId')}" placeholder="Case ID" required type="number">
      </div>
      <div class="mb-3">
        <input class="form-control" id="hearingId" value="${val('hearingId')}" placeholder="Hearing ID" required type="number">
      </div>
      <div class="mb-3">
        <input class="form-control" id="date" type="date" value="${val('date')}" required>
      </div>
      <div class="mb-3">
        <input class="form-control" id="nextDate" type="date" value="${val('nextDate')}">
      </div>
      <div class="mb-3">
        <textarea class="form-control" id="report" placeholder="Report" required>${val('report')}</textarea>
      </div>`,
    judgement: `
      <div class="mb-3">
        <input class="form-control" id="caseId" value="${val('caseId')}" placeholder="Case ID" required type="number">
      </div>
      <div class="mb-3">
        <input class="form-control" id="judgementId" value="${val('judgementId')}" placeholder="Judgement ID" required type="number">
      </div>
      <div class="mb-3">
        <input class="form-control" id="judgementDate" type="date" value="${val('judgementDate')}" required>
      </div>
      <div class="mb-3">
        <textarea class="form-control" id="verdict" placeholder="Verdict" required>${val('verdict')}</textarea>
      </div>`
  };

  return forms[type] || '<div class="alert alert-danger">Invalid form type</div>';
}